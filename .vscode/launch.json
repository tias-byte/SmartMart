{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SmartMart (Edge)",
            "request": "launch",
            "type": "dart",
            "deviceId": "edge",
            "args": [
                "--web-renderer",
                "html"
            ]
        },
        {
            "name": "SmartMart (Web Server)",
            "request": "launch",
            "type": "dart",
            "deviceId": "web-server",
            "args": [
                "--web-port",
                "8080",
                "--web-renderer",
                "html"
            ]
        },
        {
            "name": "SmartMart (Chrome)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "args": [
                "--web-renderer",
                "html"
            ]
        }
    ]
}
